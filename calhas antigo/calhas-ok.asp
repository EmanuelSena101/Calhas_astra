                    <%

                    Session.LCID = 1046
			
			        largura = request.form("largura")
                    comprimento = request.form("comprimento")
                    alturaDoTelhado = request.form("alturaDoTelhado")
                    alturaDoBeiral = request.form("alturaDoBeiral")
                    tipo = request.form("tipo")
                    cidade = request.form("cidade")
           	        data = Day(Date()) & Chr(47) & Month(Date()) & Chr(47) & Year(Date())

                    area= FormatNumber(((largura+alturaDoTelhado/2)*comprimento),0)

                    resto = FormatNumber(alturaDoBeiral-((alturaDoBeiral\3)*3),1)
         

                    if tipo=1 then
                          nome = "Barra 3 m e bocal de saída 75 mm"
                    end if

                    if tipo=2 then
                          nome = "Barras 3 m e 1 m e bocal de saída 75 mm"
                    end if

                    if tipo=3 then
                          nome = "Barra 3 m e bocal de saída 100 mm"
                    end if

                    if tipo=4 then
                          nome = "Barras 3 m e 1 m e bocal de saída 100 mm"
                    end if


                    Function RoundUp(n)
                        roundUp = Int(n) - CBool(CDbl(n) <> CLng(n))
                    End Function


                    %>


                    <div><h3 style="font-size:2.2em">Resultado:</h3></div>
                    
                    <div><h4 style="letter-spacing:0;margin-bottom:30px"><%= nome %></h4></div>


                    <div class="row margin-bottom-30">

                       <div class="col-lg-12" style="background-color:#e5e5e5">
                       
                           <div style="margin:20px 0 0 0"><img src="images/calhas-altura-largura-comprimento.png" class="img-responsive"/></div>

                            
                            <div style="margin:35px 20px 20px 20px">

                            <table style="width:100%;font-size:1.1em">
                            <tr>
                                <td style="width:7%"><img src="images/fe-calhas-letra-a.png" alt=""/></td>
                                <td style="width:53%">Largura do telhado:</td>
                                <td style="width:40%;text-align:right"><span style="font-size:1.4em;font-weight:bold"><%= largura %> m</span></td>

                            </tr>
                            </table>

                            <hr style="border: 1px #000 dotted;margin:0;margin:10px 0;opacity:0.3"/>

           

                            <table style="width:100%;font-size:1.1em">
                            <tr>
